{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnexus.dev/schema/dsl-draft.schema.json",
  "title": "Rule Lab DSL Draft",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "match", "topology", "closure", "claims"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "match": { "$ref": "./rule-dsl.schema.json#/properties/match" },
    "topology": { "$ref": "./rule-dsl.schema.json#/properties/topology" },
    "closure": { "$ref": "./rule-dsl.schema.json#/properties/closure" },
    "claims": { "$ref": "./rule-dsl.schema.json#/properties/claims" }
  }
}
