{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnexus.dev/schema/rule-lab/curation-input.schema.json",
  "type": "object",
  "required": ["run_id", "slice_id", "curated"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "slice_id": { "type": "string", "minLength": 1 },
    "curated": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "match", "topology", "closure", "claims", "confirmed_chain", "guarantees", "non_guarantees"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "rule_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "match": {
            "type": "object",
            "required": ["trigger_tokens"],
            "properties": {
              "trigger_tokens": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "symbol_kind": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "module_scope": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "topology": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["hop", "from", "to", "edge"],
              "properties": {
                "hop": { "type": "string", "minLength": 1 },
                "from": { "type": "object" },
                "to": { "type": "object" },
                "edge": {
                  "type": "object",
                  "required": ["kind"],
                  "properties": {
                    "kind": { "type": "string", "minLength": 1 }
                  }
                },
                "constraints": { "type": "object" }
              }
            }
          },
          "closure": {
            "type": "object",
            "required": ["required_hops", "failure_map"],
            "properties": {
              "required_hops": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "failure_map": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": { "type": "string", "minLength": 1 }
              }
            }
          },
          "claims": {
            "type": "object",
            "required": ["guarantees", "non_guarantees", "next_action"],
            "properties": {
              "guarantees": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "non_guarantees": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "next_action": { "type": "string", "minLength": 1 }
            }
          },
          "confirmed_chain": {
            "type": "object",
            "required": ["steps"],
            "properties": {
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["anchor", "snippet"],
                  "properties": {
                    "hop_type": { "type": "string" },
                    "anchor": { "type": "string", "minLength": 1 },
                    "snippet": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          },
          "guarantees": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "non_guarantees": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
          ,
          "resource_bindings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind"],
              "properties": {
                "kind": { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "ref_field_pattern": { "type": "string" },
                "target_entry_points": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "host_class_pattern": { "type": "string" },
                "field_name": { "type": "string" },
                "loader_methods": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "source_class_pattern": { "type": "string" },
                "source_method": { "type": "string" },
                "target_class_pattern": { "type": "string" },
                "target_method": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
