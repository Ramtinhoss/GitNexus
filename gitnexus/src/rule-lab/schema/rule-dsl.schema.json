{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnexus.dev/schema/rule-dsl.schema.json",
  "title": "Rule DSL v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "match", "topology", "closure", "claims"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger_tokens"],
      "properties": {
        "trigger_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "symbol_kind": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "module_scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "topology": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hop", "from", "to", "edge"],
        "properties": {
          "hop": { "type": "string", "minLength": 1 },
          "from": { "type": "object" },
          "to": { "type": "object" },
          "edge": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 }
            }
          },
          "constraints": { "type": "object" }
        }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_hops", "failure_map"],
      "properties": {
        "required_hops": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "failure_map": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "enum": [
              "rule_not_matched",
              "rule_matched_but_evidence_missing",
              "rule_matched_but_verification_failed",
              "gate_disabled"
            ]
          }
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guarantees", "non_guarantees", "next_action"],
      "properties": {
        "guarantees": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "non_guarantees": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "resource_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["asset_ref_loads_components", "method_triggers_field_load"]
          },
          "ref_field_pattern": { "type": "string" },
          "target_entry_points": {
            "type": "array",
            "items": { "type": "string" }
          },
          "host_class_pattern": { "type": "string" },
          "field_name": { "type": "string" },
          "loader_methods": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "lifecycle_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "additional_entry_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scope": { "type": "string" }
      }
    }
  }
}
