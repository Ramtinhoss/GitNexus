{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnexus.dev/schema/rule-lab/regress-report.schema.json",
  "type": "object",
  "required": ["pass", "failures", "metrics"],
  "properties": {
    "pass": { "type": "boolean" },
    "failures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["precision_below_threshold", "coverage_below_threshold", "probe_pass_rate_below_threshold"]
      }
    },
    "metrics": {
      "type": "object",
      "required": ["precision", "coverage", "probe_pass_rate"],
      "properties": {
        "precision": { "type": "number" },
        "coverage": { "type": "number" },
        "probe_pass_rate": { "type": "number" }
      }
    },
    "probe_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pass", "replay_command"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "pass": { "type": "boolean" },
          "replay_command": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reportPath": { "type": "string" }
  }
}
