{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitnexus.dev/schema/rule-lab/regress-report.schema.json",
  "type": "object",
  "required": ["pass", "failures", "metrics"],
  "properties": {
    "pass": { "type": "boolean" },
    "failures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["precision_below_threshold", "coverage_below_threshold"]
      }
    },
    "metrics": {
      "type": "object",
      "required": ["precision", "coverage"],
      "properties": {
        "precision": { "type": "number" },
        "coverage": { "type": "number" }
      }
    },
    "reportPath": { "type": "string" }
  }
}
